<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sky.mapper.DishFlavorsMapper">

    <insert id="save">
        insert into dish_flavor(dish_id, name, value) VALUES
        <foreach collection="flavors" item="item" separator=",">
            (#{item.dishId}, #{item.name}, #{item.value})
        </foreach>
    </insert>
    <delete id="delete">
        delete from dish_flavor where dish_id in <foreach collection="ids" item="item" separator="," open="(" close=")">
        #{item}
    </foreach>
    </delete>
</mapper>